# Fixfy Trade Portal — environment
# This app reuses the SAME Supabase database/structure as Fixfy OS (master-os).
# Point these at the same Supabase project as master-os.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (RLS bypass) — Stripe webhook + billing routes. Never expose to the client.
SERVICE_ROLE_KEY=

# Stripe (test mode for now)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring Price id for the £99/mo "Fixfy Pro" plan. Create the Product+Price in Stripe
# (test), then paste the price id here. See README / scripts.
STRIPE_PRICE_FIXFY_PRO=
